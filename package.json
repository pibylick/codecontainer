{
  "name": "@pibylick/codecontainer",
  "version": "3.4.0",
  "description": "Local AI development environment for isolated coding agents in containers with Docker, Podman, and Apple Container",
  "main": "dist/main.js",
  "bin": {
    "codecontainer": "dist/main.js"
  },
  "files": [
    "dist",
    "scripts",
    "assets",
    "Dockerfile",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && chmod u+x dist/main.js",
    "clean": "rm -rf dist",
    "start": "node dist/main.js",
    "postinstall": "node scripts/postinstall.js",
    "publish-latest": "npm run clean && npm run build && npm publish --access public",
    "publish-nightly": "npm run clean && npm run build && npm publish --tag nightly --access public",
    "test": "vitest run --passWithNoTests"
  },
  "keywords": [
    "docker",
    "apple-container",
    "podman",
    "container",
    "development",
    "development-environment",
    "dev-environment",
    "containerized-development",
    "cli",
    "ai",
    "ai-development-environment",
    "ai-coding",
    "ai-coding-agent",
    "ai-agent",
    "ai-agent-sandbox",
    "local-ai-coding",
    "claude",
    "claude-code",
    "codex",
    "codex-cli",
    "gemini",
    "gemini-cli",
    "developer-tools"
  ],
  "author": "pibylick",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.19.37",
    "typescript": "^5.9.3",
    "vitest": "^3.2.1"
  },
  "dependencies": {
    "@types/shell-quote": "^1.7.5",
    "shell-quote": "^1.7.4",
    "zod": "^4.3.6"
  }
}
